extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule" class="active") Расписание
        a(href="/admin/animals") Животные
        a(href="/admin/clients") Клиенты
        a(href="/admin/medcards") Медкарты
        if isSuperAdmin
          a(href="/admin/admins") Администраторы

      .main-panel
        .panel-header
          h1.dashboard-title Управление расписанием
          .header-actions
            a.btn.btn-secondary(href="/admin/schedule/vet") Календарь

        .card.card-export
          h3.card-title Экспорт расписания
          p.card-hint Выберите диапазон дат и ветеринара (необязательно). Пусто — экспортируется всё расписание.
          form.export-form(method="GET" action="/admin/schedule/export" id="exportForm")
            .form-grid
              .form-group.col-4
                label(for="exportDateFrom") Дата с
                input#exportDateFrom.input(type="date" name="dateFrom")
              .form-group.col-4
                label(for="exportDateTo") Дата по
                input#exportDateTo.input(type="date" name="dateTo")
              .form-group.col-4
                label(for="exportVetId") Ветеринар
                select#exportVetId.select(name="vetId")
                  option(value="") Все ветеринары
                  each vet in vets
                    option(value=vet.id)= vet.full_name
            .form-actions(style="margin-top:14px; padding-top:0; border:0")
              button.btn.btn-primary(type="submit") Экспорт CSV
              button.btn.btn-primary(type="button" onclick="submitExportXlsx()") Экспорт XLSX

        .card.card-import
          h3.card-title Импорт из Excel/CSV
          p.card-hint
            | Столбцы (любой регистр):
            strong vet_email
            |  или
            strong vet_id
            | ,
            strong date
            |  (YYYY-MM-DD),
            strong time
            |  (HH:MM). Дубли пропускаются автоматически.
          form.import-form(method="POST" action="/admin/schedule/import" enctype="multipart/form-data")
            input.input.file-input(type="file" name="file" accept=".xlsx,.xls,.csv" required)
            button.btn.btn-primary(type="submit") Импортировать
            a.btn.btn-secondary(href="/admin/schedule/import-template") Скачать шаблон XLSX

        .card
          h3.card-title Генерация слотов по диапазону дат
          form(method="POST" action="/admin/schedule/generate" id="generateForm")
            .form-grid
              .form-group.col-12
                label(for="vetId") Ветеринар *
                select#vetId.select(name="vetId" required)
                  option(value="") Выберите ветеринара...
                  each vet in vets
                    option(value=vet.id)= vet.full_name

              .form-group.col-4
                label(for="dateFrom") Дата с *
                input#dateFrom.input(type="date" name="dateFrom" required)
              .form-group.col-4
                label(for="dateTo") Дата по
                input#dateTo.input(type="date" name="dateTo")
                small.hint Пусто — только один день
              .form-group.col-4
                label Опции
                label.checkbox-inline
                  input(type="checkbox" name="skipWeekends" value="1")
                  span Пропускать выходные (Сб, Вс)

              .form-group.col-6
                label(for="fromTime") Слоты с
                input#fromTime.input(type="time" name="fromTime" value=clinic.openTime step=clinic.stepSeconds)
              .form-group.col-6
                label(for="toTime") Слоты до
                input#toTime.input(type="time" name="toTime" value=clinic.closeTime step=clinic.stepSeconds)

              .form-group.col-12
                .label-row
                  label Конкретные слоты (#{clinic.stepSeconds / 60}-мин шаг)
                  .toolbar
                    button.btn.btn-sm.btn-secondary(type="button" onclick="toggleAll(true)") Выбрать все
                    button.btn.btn-sm.btn-secondary(type="button" onclick="toggleAll(false)") Снять все
                .time-checkboxes(id="timeCheckboxes")
                  each time in clinic.times
                    label.time-chip(for=`time-${time}`)
                      input(type="checkbox" id=`time-${time}` name="times" value=time checked)
                      span= time

              .form-group.col-12
                label Исключить даты (праздники, выходные)
                .exclude-row
                  input#excludeDateInput.input(type="date")
                  button.btn.btn-secondary(type="button" onclick="addExclude()") + Добавить
                .excluded-dates(id="excludedDates")

            .form-actions
              button.btn.btn-primary.btn-lg(type="submit") Сгенерировать слоты
              a.btn.btn-secondary.btn-lg(href="/admin/schedule") Отмена

        script.
          function submitExportXlsx() {
            const form = document.getElementById('exportForm');
            const orig = form.action;
            form.action = '/admin/schedule/export.xlsx';
            form.submit();
            setTimeout(() => { form.action = orig; }, 100);
          }
          function toggleAll(checked) {
            document.querySelectorAll('#timeCheckboxes input[type=checkbox]').forEach(cb => cb.checked = checked);
          }
          ['fromTime', 'toTime'].forEach(id => {
            document.getElementById(id).addEventListener('change', () => {
              const from = document.getElementById('fromTime').value;
              const to = document.getElementById('toTime').value;
              if (!from || !to) return;
              document.querySelectorAll('#timeCheckboxes input[type=checkbox]').forEach(cb => {
                cb.checked = cb.value >= from && cb.value < to;
              });
            });
          });
          const excluded = new Set();
          function renderExcluded() {
            const el = document.getElementById('excludedDates');
            el.innerHTML = '';
            for (const d of excluded) {
              const tag = document.createElement('span');
              tag.className = 'date-tag';
              tag.innerHTML = '<span>' + d + '</span><button type="button" aria-label="Удалить">×</button>' +
                '<input type="hidden" name="excludeDates" value="' + d + '">';
              tag.querySelector('button').addEventListener('click', () => { excluded.delete(d); renderExcluded(); });
              el.appendChild(tag);
            }
          }
          function addExclude() {
            const v = document.getElementById('excludeDateInput').value;
            if (v) { excluded.add(v); renderExcluded(); document.getElementById('excludeDateInput').value = ''; }
          }

    style.
      .panel-header { display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
      .header-actions { display:flex; gap:8px; flex-wrap:wrap; }

      .card { background:#fff; border-radius:8px; padding:20px 24px; margin-bottom:20px; box-shadow:0 2px 6px rgba(0,0,0,0.06); }
      .card-import { background:#fff8e1; border-left:4px solid #ffc107; }
      .card-export { background:#e8f5e9; border-left:4px solid #4CAF50; }
      .card-title { margin:0 0 12px 0; font-size:18px; color:#2E5FA3; }
      .card-hint { font-size:13px; color:#666; margin:0 0 14px 0; line-height:1.5; }

      .import-form { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
      .file-input { flex:1; min-width:260px; padding:8px 10px; background:#fff; }
      .import-form .btn { height:42px; }

      .form-grid { display:grid; grid-template-columns:repeat(12, 1fr); gap:16px; }
      .col-12 { grid-column:span 12; }
      .col-6 { grid-column:span 6; }
      .col-4 { grid-column:span 4; }
      @media (max-width: 768px) {
        .col-6, .col-4 { grid-column:span 12; }
      }

      .form-group { display:flex; flex-direction:column; gap:6px; }
      .form-group > label { font-weight:600; font-size:14px; color:#333; }
      .hint { color:#888; font-size:12px; }

      .input, .select { height:42px; padding:0 12px; border:1px solid #ddd; border-radius:6px; font-size:14px; font-family:inherit; background:#fff; box-sizing:border-box; width:100%; }
      .input:focus, .select:focus { outline:none; border-color:#2E5FA3; box-shadow:0 0 0 3px rgba(46,95,163,0.12); }

      .checkbox-inline { display:flex; align-items:center; gap:8px; height:42px; font-weight:400; color:#555; cursor:pointer; }
      .checkbox-inline input { width:18px; height:18px; cursor:pointer; }

      .label-row { display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap; }
      .toolbar { display:flex; gap:6px; }

      .time-checkboxes { display:grid; grid-template-columns:repeat(auto-fill, minmax(80px, 1fr)); gap:6px; padding:14px; background:#f8f9fa; border-radius:6px; border:1px solid #eee; }
      .time-chip { display:flex; align-items:center; justify-content:center; gap:6px; padding:8px 10px; border:1px solid #ddd; border-radius:6px; background:#fff; cursor:pointer; font-size:13px; user-select:none; transition:all 0.15s; }
      .time-chip input { margin:0; cursor:pointer; }
      .time-chip:has(input:checked) { background:#e7f0ff; border-color:#2E5FA3; color:#2E5FA3; font-weight:600; }
      .time-chip:hover { border-color:#2E5FA3; }

      .exclude-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
      .exclude-row .input { flex:0 0 200px; }
      .exclude-row .btn { height:42px; white-space:nowrap; }

      .excluded-dates { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; min-height:8px; }
      .date-tag { display:inline-flex; align-items:center; gap:6px; padding:6px 10px; background:#fff0f0; border:1px solid #fdd; border-radius:6px; font-size:13px; color:#a33; }
      .date-tag button { border:0; background:transparent; cursor:pointer; color:#c00; font-size:16px; line-height:1; padding:0 2px; }
      .date-tag button:hover { color:#900; }

      .form-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-top:20px; padding-top:16px; border-top:1px solid #eee; }

      .btn { height:38px; padding:0 16px; border:none; border-radius:6px; cursor:pointer; text-decoration:none; font-size:14px; display:inline-flex; align-items:center; justify-content:center; line-height:1; font-family:inherit; box-sizing:border-box; }
      .btn-sm { height:32px; padding:0 12px; font-size:12px; }
      .btn-lg { height:44px; padding:0 22px; font-size:15px; font-weight:600; }
      .btn-primary { background:#2E5FA3; color:#fff; }
      .btn-primary:hover { background:#244c87; }
      .btn-secondary { background:#6c757d; color:#fff; }
      .btn-secondary:hover { background:#5a6268; }

extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule" class="active") Расписание
        a(href="/admin/clients") Клиенты
        if isSuperAdmin
          a(href="/admin/admins") Администраторы

      .main-panel
        h1.dashboard-title Управление расписанием

        .form-wrapper
          h3 Генерация слотов
          form(method="POST" action="/admin/schedule/generate" id="generateForm")
            .form-row
              .form-group
                label(for="vetId") Ветеринар *
                select#vetId(name="vetId" required)
                  option(value="") Выберите ветеринара...
                  each vet in vets
                    option(value=vet.id)= vet.full_name

              .form-group
                label(for="date") Дата *
                input#date(type="date" name="date" required)

            .form-group
              label Время приёмов (выберите несколько):
              .time-checkboxes
                - const times = ['09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00'];
                each time in times
                  .checkbox-item
                    input(type="checkbox" id=`time-${time}` name="times" value=time)
                    label(for=`time-${time}`)= time

            .form-actions
              button.btn.btn-primary(type="submit") Сгенерировать слоты
              a.btn.btn-secondary(href="/admin/schedule") Отмена

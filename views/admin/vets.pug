extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets" class="active") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule") Расписание
        a(href="/admin/clients") Клиенты

      .main-panel
        h1.dashboard-title Управление ветеринарами
        a.btn.btn-primary(href="/admin/vets/new") + Добавить ветеринара

        .table-responsive
          table
            thead
              tr
                th ФИО
                th Специализация
                th Опыт
                th Действия
            tbody
              tr
                td colspan="4" Ветеринаров нет

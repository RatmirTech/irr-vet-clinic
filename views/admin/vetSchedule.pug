extends ../layout/base.pug

block content
  style.
    .schedule-header { display:flex; align-items:center; gap:16px; margin-bottom:20px; flex-wrap:wrap; }
    .month-nav { display:flex; align-items:center; gap:12px; }
    .month-label { font-size:1.2rem; font-weight:600; min-width:180px; text-align:center; }
    .calendar-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; margin-top:16px; }
    .cal-head { text-align:center; font-weight:600; color:var(--color-primary); padding:8px 0; font-size:.85rem; }
    .cal-day { min-height:100px; border:1px solid #e2e8f0; border-radius:8px; padding:6px; background:#fff; }
    .cal-day.empty { background:transparent; border:none; }
    .cal-day.today { border-color:var(--color-primary); background:#f0f4ff; }
    .cal-day-num { font-size:.8rem; font-weight:600; color:#64748b; margin-bottom:4px; }
    .cal-day.today .cal-day-num { color:var(--color-primary); }
    .appt-chip { border-radius:4px; padding:3px 6px; font-size:.72rem; margin-bottom:3px; cursor:pointer; line-height:1.3; }
    .appt-chip.pending { background:#fef3c7; color:#92400e; }
    .appt-chip.confirmed { background:#d1fae5; color:#065f46; }
    .appt-chip.completed { background:#e0e7ff; color:#3730a3; }
    .appt-chip.cancelled { background:#fee2e2; color:#991b1b; text-decoration:line-through; }
    .appt-chip:hover { opacity:.85; }
    .legend { display:flex; gap:12px; flex-wrap:wrap; margin-top:8px; font-size:.8rem; }
    .legend-item { display:flex; align-items:center; gap:4px; }
    .legend-dot { width:12px; height:12px; border-radius:3px; }
    .vet-filter-form { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
    .detail-panel { margin-top:24px; }
    .appt-table th, .appt-table td { vertical-align:middle; }
    .status-badge { padding:2px 8px; border-radius:12px; font-size:.75rem; font-weight:600; }

  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule" class="active") Расписание
        a(href="/admin/clients") Клиенты
        a(href="/admin/medcards") Медкарты
        a(href="/admin/animals") Животные
        if isSuperAdmin
          a(href="/admin/admins") Администраторы

      .main-panel
        h1.dashboard-title Расписание ветеринара

        .schedule-header
          form.vet-filter-form(method="GET" action="/admin/schedule/vet")
            select(name="vetId" style="padding:8px 12px;border:1px solid #e2e8f0;border-radius:6px;font-size:.9rem")
              option(value="") — Выберите ветеринара —
              each vet in vets
                option(value=vet.id selected=(vet.id == selectedVetId))= vet.full_name
            input(type="hidden" name="month" value=currentMonth)
            button.btn.btn-primary(type="submit") Показать

          .month-nav
            a.btn.btn-secondary(href=`/admin/schedule/vet?vetId=${selectedVetId}&month=${prevMonth}`) ←
            span.month-label= monthLabel
            a.btn.btn-secondary(href=`/admin/schedule/vet?vetId=${selectedVetId}&month=${nextMonth}`) →

        .legend
          .legend-item
            .legend-dot(style="background:#fef3c7;border:1px solid #f59e0b")
            span Ожидание
          .legend-item
            .legend-dot(style="background:#d1fae5;border:1px solid #10b981")
            span Подтверждена
          .legend-item
            .legend-dot(style="background:#e0e7ff;border:1px solid #6366f1")
            span Завершена
          .legend-item
            .legend-dot(style="background:#fee2e2;border:1px solid #ef4444")
            span Отменена

        .calendar-grid
          each day in ['Пн','Вт','Ср','Чт','Пт','Сб','Вс']
            .cal-head= day

          - for (let i = 0; i < firstDayOfWeek; i++)
            .cal-day.empty

          - for (let d = 1; d <= daysInMonth; d++)
            - const isToday = isCurrentMonth && d === today
            .cal-day(class=isToday ? 'today' : '')
              .cal-day-num= d
              if byDay[d]
                each appt in byDay[d]
                  .appt-chip(class=appt.status title=`${appt.client_name} — ${appt.animal_name}`)
                    strong= appt.slot_time.slice(0,5)
                    |  #{appt.animal_name}
                    br
                    small= appt.client_name

        if selectedVetId
          .detail-panel
            h2 Все визиты за #{monthLabel}
            if !Object.keys(byDay).length
              p.text-muted Нет записей в этом месяце

            else
              table.table.appt-table
                thead
                  tr
                    th Дата
                    th Время
                    th Пациент
                    th Вид
                    th Клиент
                    th Услуга
                    th Заметки
                    th Статус
                tbody
                  - const allAppts = Object.values(byDay).flat().sort((a,b) => new Date(a.slot_date)-new Date(b.slot_date) || a.slot_time.localeCompare(b.slot_time))
                  each appt in allAppts
                    tr
                      td= new Date(appt.slot_date).toLocaleDateString('ru-RU')
                      td= appt.slot_time.slice(0,5)
                      td= appt.animal_name
                      td= appt.species || '—'
                      td= appt.client_name
                      td= appt.service_name || '—'
                      td= appt.notes || '—'
                      td
                        - const labels = {pending:'Ожидание',confirmed:'Подтверждена',completed:'Завершена',cancelled:'Отменена'}
                        - const colors = {pending:'#f59e0b',confirmed:'#10b981',completed:'#6366f1',cancelled:'#ef4444'}
                        span.status-badge(style=`background:${colors[appt.status]}20;color:${colors[appt.status]}`)= labels[appt.status] || appt.status

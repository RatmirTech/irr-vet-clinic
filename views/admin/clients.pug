extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule") Расписание
        a(href="/admin/animals") Животные
        a(href="/admin/clients" class="active") Клиенты
        a(href="/admin/medcards") Медкарты
        if isSuperAdmin
          a(href="/admin/admins") Администраторы

      .main-panel
        .panel-header(style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px")
          h1.dashboard-title Управление клиентами
          a.btn.btn-primary(href="/admin/clients/new") + Новый клиент

        if clients && clients.length > 0
          .table-responsive
            table
              thead
                tr
                  th ФИО
                  th Email
                  th Телефон
                  th Животных
                  th Дата регистрации
                  th Действия
              tbody
                each client in clients
                  tr
                    td= client.full_name
                    td= client.email || '-'
                    td= client.phone || '-'
                    td= client.animal_count || 0
                    td= client.created_at ? new Date(client.created_at).toLocaleDateString('ru-RU') : '-'
                    td(style="display:flex; gap:4px")
                      a.btn.btn-sm.btn-secondary(href=`/admin/clients/${client.id}/animals/new`) + Питомец
                      a.btn.btn-sm.btn-primary(href=`/admin/clients/${client.id}/appointments/new`) + Запись

          if pagination
            .pagination
              if pagination.hasPrev
                a.btn.btn-secondary(href=`/admin/clients?page=${pagination.page - 1}`) ← Назад

              span.page-info
                | Страница #{pagination.page} из #{pagination.totalPages}

              if pagination.hasNext
                a.btn.btn-secondary(href=`/admin/clients?page=${pagination.page + 1}`) Вперед →
        else
          .empty-state
            h3 Клиентов нет
            p Когда клиенты зарегистрируются, они появятся здесь

    style.
      .btn-sm { padding: 4px 10px; font-size: 12px; }
      .btn-primary { background:#007bff; color:white; padding:8px 16px; border:none; border-radius:4px; text-decoration:none; display:inline-block; }
      .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
        padding: 20px;
      }

      .page-info {
        font-weight: 600;
        color: #666;
      }

      .btn.btn-secondary {
        background-color: #999;
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
      }

      .btn.btn-secondary:hover {
        background-color: #777;
      }

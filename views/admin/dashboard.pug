extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard" class="active") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule") Расписание
        a(href="/admin/animals") Животные
        a(href="/admin/clients") Клиенты
        a(href="/admin/medcards") Медкарты
        if isSuperAdmin
          a(href="/admin/admins") Администраторы

      .main-panel
        h1.dashboard-title Панель администратора

        .stats-grid
          .stat-card
            h4 Ветеринаров
            .number= (stats && stats.vets) || 0
          .stat-card
            h4 Клиентов
            .number= (stats && stats.clients) || 0
          .stat-card
            h4 Услуг
            .number= (stats && stats.services) || 0
          .stat-card
            h4 Записей сегодня
            .number= (stats && stats.appointments) || 0

        .info-section
          h2 Добро пожаловать в панель администратора!
          p Здесь вы можете управлять всеми аспектами работы клиники.

          .quick-actions
            h3 Быстрые действия
            .card-actions
              a.btn.btn-primary(href="/admin/vets/new") + Добавить ветеринара
              a.btn.btn-primary(href="/admin/services/new") + Добавить услугу
              a.btn.btn-secondary(href="/admin/schedule") Генерация слотов
              a.btn.btn-secondary(href="/admin/schedule/vet") Расписание ветеринаров

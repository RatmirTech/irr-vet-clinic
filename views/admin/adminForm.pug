extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню администратора
        a(href="/admin/dashboard") Дашборд
        a(href="/admin/vets") Ветеринары
        a(href="/admin/services") Услуги
        a(href="/admin/schedule") Расписание
        a(href="/admin/clients") Клиенты
        a(href="/admin/medcards") Медкарты
        a(href="/admin/animals") Животные
        if isSuperAdmin
          a(href="/admin/admins" class="active") Администраторы

      .main-panel
        h1.dashboard-title= adminUser ? 'Редактировать администратора' : 'Добавить администратора'

        if error
          .flash-message.flash-error
            = error

        .form-wrapper
          form(method="POST" enctype="multipart/form-data" action=adminUser ? `/admin/admins/${adminUser.id}` : '/admin/admins')
            .form-row
              .form-group
                label(for="fullName") ФИО *
                input#fullName(type="text" name="fullName" value=(adminUser ? adminUser.full_name : '') required)

              .form-group
                label(for="email") Email *
                input#email(type="email" name="email" value=(adminUser ? adminUser.email : '') required disabled=(adminUser ? true : false))

            if !adminUser
              .form-group
                label(for="password") Пароль *
                input#password(type="password" name="password" required placeholder="Минимум 6 символов")

            .form-row
              .form-group
                label(for="phone") Телефон
                input#phone(type="text" name="phone" value=(adminUser ? adminUser.phone : '') placeholder="+7 (999) 000-00-00")

              .form-group
                label(for="position") Должность
                input#position(type="text" name="position" value=(adminUser ? adminUser.position : '') placeholder="Менеджер, Старший администратор...")

            .form-group
              label(for="photo") Фото
              input#photo(type="file" name="photo" accept="image/*")
              if adminUser && adminUser.photo_url
                .photo-preview
                  img(src=adminUser.photo_url style="max-width:150px; border-radius:4px; margin-top:8px")

            .form-actions
              button.btn.btn-primary(type="submit")= adminUser ? 'Сохранить изменения' : 'Добавить администратора'
              a.btn.btn-secondary(href="/admin/admins") Отмена

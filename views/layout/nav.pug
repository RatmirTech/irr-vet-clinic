if isAuthenticated
  case role
    when 'admin'
      a(href="/admin/dashboard") Панель администратора
      a(href="/admin/vets") Ветеринары
      a(href="/admin/services") Услуги
      a(href="/admin/schedule") Расписание
      a(href="/admin/clients") Клиенты
      a(href="/auth/logout") Выход
    when 'vet'
      a(href="/vet/dashboard") Мой кабинет
      a(href="/vet/schedule") Расписание
      a(href="/") Главная
      a(href="/auth/logout") Выход
    when 'client'
      a(href="/client/dashboard") Мой кабинет
      a(href="/client/animals") Мои питомцы
      a(href="/client/profile") Мой профиль
      a(href="/") Главная
      a(href="/auth/logout") Выход
else
  a(href="/") Главная
  a(href="/vets") Ветеринары
  a(href="/services") Услуги
  a(href="/auth/login") Вход
  a(href="/auth/register") Регистрация

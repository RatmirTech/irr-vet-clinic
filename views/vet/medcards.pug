extends ../layout/base.pug

block content
  .container
    .dashboard
      .sidebar
        h3 Меню ветеринара
        a(href="/vet/dashboard") Дашборд
        a(href="/vet/appointments") Приёмы
        a(href="/vet/schedule") Расписание
        a(href="/vet/medcards" class="active") Медкарты

      .main-panel
        h1.dashboard-title Медицинские карты

        .search-bar(style="margin-bottom:16px; display:flex; gap:8px; align-items:center")
          input#medcardSearch(type="text" placeholder="Поиск по имени, виду, породе или владельцу..." style="flex:1; padding:10px 14px; border:1px solid #ddd; border-radius:6px; font-size:14px")
          select#speciesFilter(style="padding:10px; border:1px solid #ddd; border-radius:6px")
            option(value="") Все виды
          span#resultCount(style="color:#666; font-size:13px; white-space:nowrap")

        if medCards && medCards.length > 0
          .medcards-grid#medcardsGrid
            each card in medCards
              .medcard-item(data-name=(card.animal.name || '').toLowerCase() data-species=(card.animal.species || '').toLowerCase() data-breed=(card.animal.breed || '').toLowerCase() data-client=(card.animal.client_name || '').toLowerCase())
                if card.animal.photo_url
                  img.medcard-photo(src=card.animal.photo_url alt=card.animal.name)
                else
                  .medcard-photo-placeholder 📋

                .medcard-info
                  h3= card.animal.name
                  p.species= card.animal.species
                  p.visit-count Приёмов: #{card.visitCount}

                .medcard-actions
                  a.btn.btn-primary(href=`/vet/medcards/${card.animal.id}`) Просмотр
                  a.btn.btn-secondary(href=`/vet/medcards/${card.animal.id}/visits/new`) Новый приём
        else
          .empty-state
            h3 Нет медкарт
            p Медкарты появятся, когда животные будут добавлены в систему

        script.
          (function() {
            const input = document.getElementById('medcardSearch');
            const speciesSel = document.getElementById('speciesFilter');
            const counter = document.getElementById('resultCount');
            const items = Array.from(document.querySelectorAll('#medcardsGrid .medcard-item'));
            if (!items.length) return;
            const speciesSet = new Set();
            items.forEach(i => { if (i.dataset.species) speciesSet.add(i.dataset.species); });
            Array.from(speciesSet).sort().forEach(s => {
              const opt = document.createElement('option');
              opt.value = s;
              opt.textContent = s.charAt(0).toUpperCase() + s.slice(1);
              speciesSel.appendChild(opt);
            });
            function apply() {
              const q = input.value.trim().toLowerCase();
              const sp = speciesSel.value;
              let visible = 0;
              items.forEach(it => {
                const matchQ = !q || it.dataset.name.includes(q) || it.dataset.species.includes(q) || it.dataset.breed.includes(q) || it.dataset.client.includes(q);
                const matchS = !sp || it.dataset.species === sp;
                const show = matchQ && matchS;
                it.style.display = show ? '' : 'none';
                if (show) visible++;
              });
              counter.textContent = `Найдено: ${visible} из ${items.length}`;
            }
            input.addEventListener('input', apply);
            speciesSel.addEventListener('change', apply);
            apply();
          })();

    style.
      .medcards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-top: 24px;
      }

      .medcard-item {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
      }

      .medcard-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      }

      .medcard-photo {
        width: 100%;
        height: 200px;
        object-fit: cover;
        background: #f5f5f5;
      }

      .medcard-photo-placeholder {
        width: 100%;
        height: 200px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
      }

      .medcard-info {
        padding: 16px;
      }

      .medcard-info h3 {
        margin: 0 0 8px 0;
        font-size: 18px;
      }

      .medcard-info .species {
        color: #666;
        font-size: 14px;
        margin: 0 0 8px 0;
      }

      .medcard-info .visit-count {
        color: #999;
        font-size: 13px;
        margin: 0;
      }

      .medcard-actions {
        padding: 0 16px 16px 16px;
        display: flex;
        gap: 8px;
      }

      .medcard-actions .btn {
        flex: 1;
        padding: 8px 12px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        font-size: 13px;
        text-align: center;
      }

      .btn-primary {
        background-color: #4CAF50;
        color: white;
      }

      .btn-primary:hover {
        background-color: #45a049;
      }

      .btn-secondary {
        background-color: #999;
        color: white;
      }

      .btn-secondary:hover {
        background-color: #777;
      }

      .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #666;
      }

      .empty-state h3 {
        margin-bottom: 12px;
      }

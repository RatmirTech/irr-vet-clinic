extends ../layout/base.pug

block content
  .auth-container
    .auth-card
      h2 Регистрация

      if error
        .flash-message.flash-error
          span.close-btn ✕
          = error

      form(method="POST" action="/auth/register" id="registerForm")
        .form-group
          label(for="fullName") ФИО
          input#fullName(type="text" name="fullName" required placeholder="Ваше полное имя")

        .form-group
          label(for="email") Email
          input#email(type="email" name="email" required placeholder="your@email.com")

        .form-group
          label(for="phone") Телефон (опционально)
          input#phone(type="tel" name="phone" placeholder="+7 (999) 999-99-99")

        .form-group
          label(for="password") Пароль
          input#password(type="password" name="password" required placeholder="Минимум 6 символов")

        .form-group
          label(for="confirmPassword") Подтверждение пароля
          input#confirmPassword(type="password" name="confirmPassword" required placeholder="Повторите пароль")

        button(type="submit") Зарегистрироваться

      .auth-links
        p Уже есть аккаунт?
          a(href="/auth/login") Войдите
        p
          a(href="/") Вернуться на главную

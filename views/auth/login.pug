extends ../layout/base.pug

block content
  .auth-container
    .auth-card
      h2 Вход в систему

      if error
        .flash-message.flash-error
          span.close-btn ✕
          = error

      form(method="POST" action="/auth/login" id="loginForm")
        .form-group
          label(for="email") Email
          input#email(type="email" name="email" required placeholder="your@email.com")

        .form-group
          label(for="password") Пароль
          input#password(type="password" name="password" required placeholder="Минимум 6 символов")

        button(type="submit") Вход

      .auth-links
        p Нет аккаунта?
          a(href="/auth/register") Зарегистрируйтесь
        p
          a(href="/") Вернуться на главную

extends ../layout/base.pug

block content
  .container
    .hero
      h1 Добро пожаловать в ветеринарную клинику
      p Лучший уход для ваших питомцев
      if isAuthenticated
        if role === 'client'
          a.btn.btn-primary(href="/client/dashboard") Мой кабинет
          a.btn.btn-secondary(href="/appointments/new") Записаться на приём
        else if role === 'vet'
          a.btn.btn-primary(href="/vet/dashboard") Мой кабинет
        else if role === 'admin'
          a.btn.btn-primary(href="/admin/dashboard") Панель администратора
      else
        a.btn.btn-primary(href="/auth/login") Войти
        a.btn.btn-secondary(href="/auth/register") Зарегистрироваться

    if featuredVets && featuredVets.length > 0
      .vets-preview
        h2 Наши ветеринары
        .vets-grid
          each vet in featuredVets
            .vet-card
              .card-image
                img(src=vet.photo_url || "/images/logo.png" alt=vet.full_name)
                .card-overlay
                  a(href=`/vets/${vet.id}`) Подробнее
              .card-content
                h3= vet.full_name
                .specialization= vet.specialization
                .experience Опыт: #{vet.experience || 0} лет
                .bio= vet.bio

    if featuredServices && featuredServices.length > 0
      .services-preview
        h2 Наши услуги
        .services-grid
          each service in featuredServices
            .service-card
              .card-image
                img(src=service.photo_url || "/images/logo.png" alt=service.name)
                .card-overlay
                  a(href="/services") Все услуги
              .card-content
                h3= service.name
                .description= service.description
                .price= '₽ ' + service.price
                .duration Время: #{service.duration_min || 0} мин

    .info-section
      h2 О нас
      p Мы предоставляем высококачественные ветеринарные услуги для всех видов домашних животных.
      p Наш опытный персонал готов помочь вашим питомцам быть здоровыми и счастливыми.

      if !isAuthenticated
        .cta-block
          h3 Готовы записаться?
          a.btn.btn-primary(href="/auth/register") Зарегистрируйтесь сейчас
          p или
          a(href="/auth/login") войдите в свой аккаунт

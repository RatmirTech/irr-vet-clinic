extends ../layout/base.pug

block content
  .container
    .hero
      h1 Добро пожаловать в ветеринарную клинику
      p Лучший уход для ваших питомцев
      if isAuthenticated
        if role === 'client'
          a.btn.btn-primary(href="/client/dashboard") Мой кабинет
          a.btn.btn-secondary(href="/client/appointments/new") Записаться на приём
        else if role === 'vet'
          a.btn.btn-primary(href="/vet/dashboard") Мой кабинет
        else if role === 'admin'
          a.btn.btn-primary(href="/admin/dashboard") Панель администратора
      else
        a.btn.btn-primary(href="/auth/login") Войти
        a.btn.btn-secondary(href="/auth/register") Зарегистрироваться

    if featuredVets && featuredVets.length > 0
      .vets-preview
        h2 Наши ветеринары
        .vets-grid
          each vet in featuredVets
            .vet-card
              .card-image
                img(src=vet.photo_url || "/images/logo.png" alt=vet.full_name)
                .card-overlay
                  a(href=`/vets/${vet.id}`) Подробнее
              .card-content
                h3= vet.full_name
                .specialization= vet.specialization
                .experience Опыт: #{vet.experience || 0} лет
                .bio= vet.bio

    if featuredServices && featuredServices.length > 0
      .services-preview
        h2 Наши услуги
        .services-grid
          each service in featuredServices
            .service-card
              .card-image
                img(src=service.photo_url || "/images/logo.png" alt=service.name)
              .card-content
                h3.service-name= service.name
                .description= service.description
                .price-row
                  .price= '₽ ' + service.price
                  .duration Время: #{service.duration_min || 0} мин

    style.
      .services-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:24px; }
      .service-card { display:flex; flex-direction:column; background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.08); transition:transform 0.15s, box-shadow 0.15s; }
      .service-card:hover { transform:translateY(-3px); box-shadow:0 6px 18px rgba(0,0,0,0.12); }
      .service-card .card-image { width:100%; height:240px; background:#f5f5f5; overflow:hidden; flex-shrink:0; }
      .service-card .card-image img { width:100%; height:100%; object-fit:cover; display:block; }
      .service-card .card-content { padding:18px 20px 20px; display:flex; flex-direction:column; flex:1; gap:10px; }
      .service-card .service-name { margin:0; font-size:18px; color:#2E5FA3; line-height:1.3; min-height:48px; display:flex; align-items:flex-start; }
      .service-card .description { color:#555; font-size:14px; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; text-overflow:ellipsis; min-height:42px; }
      .service-card .price-row { margin-top:auto; padding-top:12px; border-top:1px solid #eee; }
      .service-card .price { color:#28a745; font-size:24px; font-weight:700; line-height:1.2; }
      .service-card .duration { color:#888; font-size:13px; margin-top:4px; }

    .info-section
      h2 О нас
      p Мы предоставляем высококачественные ветеринарные услуги для всех видов домашних животных.
      p Наш опытный персонал готов помочь вашим питомцам быть здоровыми и счастливыми.

      if !isAuthenticated
        .cta-block
          h3 Готовы записаться?
          a.btn.btn-primary(href="/auth/register") Зарегистрируйтесь сейчас
          p или
          a(href="/auth/login") войдите в свой аккаунт
